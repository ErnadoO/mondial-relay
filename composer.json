{
    "name": "ernadoo/mondial-relay",
    "type": "library",
    "description": "Mondial Relay API client — V2 REST (label creation) + SOAP (relay point search)",
    "keywords": ["mondial-relay", "shipping", "carrier", "label", "relay-point"],
    "license": "MIT",
    "authors": [
        {
            "name": "Erwan Nader",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-soap": "*",
        "ext-simplexml": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1 || ^2.0"
    },
    "require-dev": {
        "nyholm/psr7": "^1.8",
        "phpstan/phpstan": "^1.11",
        "phpunit/phpunit": "^11.0"
    },
    "suggest": {
        "symfony/http-client": "PSR-18 implementation — Psr18Client also implements PSR-17 factories",
        "guzzlehttp/guzzle": "PSR-18 implementation with GuzzleHttp\\Psr7\\HttpFactory for PSR-17"
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse"
    },
    "autoload": {
        "psr-4": {
            "Ernadoo\\MondialRelay\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ernadoo\\MondialRelay\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
